# Used by Docker Compose and local server development
POSTGRES_DB=examflow
POSTGRES_USER=examflow
POSTGRES_PASSWORD=examflow_password
DATABASE_URL=postgresql://examflow:examflow_password@localhost:5432/examflow
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=8h
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
SEED_DATABASE=true
